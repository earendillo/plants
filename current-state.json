    "auth": ["Email/Pass", "GoogleOAuth", "PassReset", "Auth-guarded-middleware"],
    "gardens": "Multi-tenant|Roles(owner,limited_editor)|Invite-links|Guest-JWT(is_valid_guest_token)",
    "plants": {
      "logic": "Interval-scheduling|RPCs(water_plant,feed_plant)|GuestRPC(water_plant_guest only)|collectDueItems@/lib/due-items.ts",
      "crud": "Create(/plants/new)|Edit(/plants/[id])|Delete(DeletePlantDialog)|List(/plants)",
