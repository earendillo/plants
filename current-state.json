      "ui": ["PlantCard", "DueCard", "PlantForm", "PlantFormFields", "PlantEditHero", "PlantTypeSelector", "PlantDetailTabs", "DeletePlantDialog", "PlantIcon", "GardenSelect"]
    },
    "profile": "Fields(displayName,avatarUrl,timezone)|Table:profiles|ProfileForm",
    "guest": "GuestPlantList|GuestTokenValidator|Anonymous-share-links"
  },
  "types": {
    "source": "/types/supabase.ts",
    "status": "synchronized_with_db",
    "generated_at": "2026-05-02",
    "convention": "snake_case (strictly match DB columns)",
    "helpers": "/types/index.ts (Plant,Garden,ActivityLog,Profile,GardenMember,GardenRole,ActivityType,PlantType,PLANT_TYPES)"
  },
  "paths": {
    "types": "/types/index.ts",
    "supabaseTypes": "/types/supabase.ts",
    "db": "/lib/db/{plants,gardens,profiles,anonymous-links}.ts",
    "utils": "/lib/utils.ts",
    "validation": "/lib/validation.ts",
    "apiError": "/lib/api-error.ts",
    "dueItems": "/lib/due-items.ts",
    "plantIconPaths": "/lib/plant-icon-paths.tsx",
    "components": "/components/",
    "uiLib": "/components/ui/",
    "api": "/app/api/{plants,gardens,profile,guest,share}/",
    "pages": "/app/(authenticated)/{today,plants,profile}/",
    "migrations": "/supabase/migrations/"
  },
  "db": ["plants", "gardens", "garden_members", "garden_share_links", "profiles", "activity_logs"],
  "components": {
    "layout": ["TopBar", "BottomTabBar", "GardenHeader", "GardenTabs", "GardenContentWrapper", "GardenPicker", "GardenNavigationContext"],
    "plants": ["PlantCard", "DueCard", "PlantForm", "PlantFormFields", "PlantEditHero", "PlantTypeSelector", "PlantDetailTabs", "PlantIcon", "DeletePlantDialog", "PlantsPageSkeleton", "GardenSelect"],
    "actions": ["ActionButton", "ActivityTimeline"],
