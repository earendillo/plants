{
  "pj": "plant-watering-tracker",
  "stack": "Next16(AppRouter)|TS(Strict)|Supabase(RLS+SSR)|TW4+shadcn|next-intl4",
  "arch": {
    "da": "Server-modules@/lib/db/",
    "api": "RouteHandlers+Zod+handleApiError+uuidParam",
    "auth": "JWT-Cookies+Middleware+Guest-JWT(HS256)",
    "nav": "Top:Sticky+Sheet|Bottom:3-tab(Today,Plants,Add)",
    "i18n": "next-intl4|en+pl|messages/{en,pl}.json|namespaces:nav,today,plants,plantNew,plantEdit,plantCard,dueCard,actionButton,plantForm,plantFormFields,gardenHeader,shareDialog,gardenPicker,guestPlantList,login,forgotPassword,profile,activityTimeline,setPassword"
  },
